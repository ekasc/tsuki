# Optional: point browser API calls at another origin.
# Leave empty to use same-origin routes.
VITE_API_BASE_URL=

# Browser feature flag for local upload UI.
# 1 = enabled (default), 0 = hide/disable local upload UI.
VITE_LOCAL_LIBRARY_ENABLED=1

# Server feature flag for local upload/library APIs.
# 1 = enabled (default), 0 = return 503 for local-library endpoints.
TSUKI_LOCAL_LIBRARY_ENABLED=1

# Optional comma-separated allowlist additions for remote image hosts.
WEBCENTRAL_CDN_HOSTS=

# WeebCentral API route request limits (per client IP, per minute).
WEBCENTRAL_SCRAPE_RATE_LIMIT_PER_MINUTE=90
WEBCENTRAL_SCRAPE_PREFETCH_RATE_LIMIT_PER_MINUTE=24
WEBCENTRAL_SCRAPE_FORCE_REFRESH_RATE_LIMIT_PER_MINUTE=6
WEBCENTRAL_IMAGE_RATE_LIMIT_PER_MINUTE=240
WEBCENTRAL_IMAGE_PREFETCH_RATE_LIMIT_PER_MINUTE=60

# WeebCentral upstream guardrails.
WEBCENTRAL_UPSTREAM_GLOBAL_RATE_LIMIT_PER_MINUTE=1200
WEBCENTRAL_UPSTREAM_MAX_CONCURRENT_REQUESTS=10
WEBCENTRAL_UPSTREAM_TIMEOUT_MS=8000
WEBCENTRAL_UPSTREAM_RETRY_COUNT=1
WEBCENTRAL_UPSTREAM_RETRY_BASE_DELAY_MS=220
WEBCENTRAL_UPSTREAM_CIRCUIT_FAILURE_WINDOW_MS=60000
WEBCENTRAL_UPSTREAM_CIRCUIT_FAILURE_THRESHOLD=10
WEBCENTRAL_UPSTREAM_CIRCUIT_OPEN_MS=45000

# WeebCentral payload cache tuning.
WEBCENTRAL_SERIES_CACHE_TTL_MS=600000
WEBCENTRAL_SERIES_CACHE_STALE_TTL_MS=1200000
WEBCENTRAL_CHAPTER_CACHE_TTL_MS=3600000
WEBCENTRAL_CHAPTER_CACHE_STALE_TTL_MS=1800000

# Proxy upload limits.
TSUKI_UPLOAD_RATE_LIMIT_PER_MINUTE=12
