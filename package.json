{
  "name": "suki",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:type": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=chromium-desktop",
    "test:e2e:mobile": "playwright test --project=webkit-iphone15pro --project=chromium-galaxys24 --project=webkit-ipadpro11",
    "test:visual": "VISUAL_REGRESSION=1 playwright test tests/e2e/visual-reader.spec.ts",
    "test:lighthouse": "LHCI_CHROME_PATH=\"$(node -e 'const { chromium } = require(\"@playwright/test\"); console.log(chromium.executablePath())')\" lhci autorun --config=./lighthouserc.json",
    "test:ci": "pnpm test:type && pnpm test:unit && pnpm build && pnpm test:e2e:desktop && pnpm test:e2e:mobile && pnpm test:visual",
    "lint": "tsc --noEmit",
    "format": "prettier --check .",
    "check": "prettier --write .",
    "playwright": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/react-router": "1.132.0",
    "@tanstack/react-start": "1.132.0",
    "@tanstack/react-virtual": "3.13.12",
    "@tanstack/router-plugin": "1.132.0",
    "better-sqlite3": "11.10.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-kit": "0.31.8",
    "drizzle-orm": "0.45.0",
    "file-type": "21.0.0",
    "jszip": "3.10.1",
    "lucide-react": "0.561.0",
    "mime-types": "3.0.1",
    "nanoid": "5.1.6",
    "next-themes": "^0.4.6",
    "p-limit": "7.1.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "0.34.4",
    "tailwind-merge": "3.0.2",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "1.3.6",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@lhci/cli": "^0.14.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.2.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/mime-types": "3.0.1",
    "@types/node": "22.10.2",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "5.0.4",
    "prettier": "3.5.3",
    "tsx": "4.0.0",
    "typescript": "5.7.2",
    "vite": "7.1.7",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.0.5"
  }
}
