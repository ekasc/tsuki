{
  "name": "tsuki",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:cloudflare": "VITE_LOCAL_LIBRARY_ENABLED=0 vite build",
    "verify:release:v1": "node scripts/verify-v1-online-release.mjs",
    "preview": "vite preview",
    "deploy:cloudflare:dry": "VITE_LOCAL_LIBRARY_ENABLED=0 vite build && npx --yes wrangler@4.69.0 deploy --dry-run --config dist/server/wrangler.json --env=\"\"",
    "deploy:cloudflare": "VITE_LOCAL_LIBRARY_ENABLED=0 vite build && npx --yes wrangler@4.69.0 deploy --config dist/server/wrangler.json --env=\"\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:type": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=chromium-desktop",
    "test:e2e:mobile": "playwright test --project=webkit-iphone15pro --project=chromium-galaxys24 --project=webkit-ipadpro11",
    "test:visual": "echo \"Visual regression tests removed\"",
    "test:lighthouse": "pnpm build && LHCI_CHROME_PATH=\"$(node -e 'const { chromium } = require(\"@playwright/test\"); console.log(chromium.executablePath())')\" lhci autorun --config=./lighthouserc.json",
    "test:ci": "pnpm test:type && pnpm test:unit && pnpm build && pnpm test:e2e:desktop && pnpm test:e2e:mobile",
    "lint": "tsc --noEmit",
    "format": "prettier --check .",
    "check": "prettier --write .",
    "playwright": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.27",
    "@tanstack/react-virtual": "3.14.5",
    "@tanstack/router-plugin": "1.168.19",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "file-type": "22.0.1",
    "gsap": "^3.15.0",
    "jszip": "3.10.1",
    "lucide-react": "1.23.0",
    "mime-types": "3.0.2",
    "nanoid": "5.1.16",
    "next-themes": "^0.4.6",
    "p-limit": "7.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.3",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/mime-types": "3.0.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-kit": "0.31.10",
    "prettier": "3.9.4",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.9.0",
  "onlyBuiltDependencies": [
    "better-sqlite3",
    "sharp"
  ]
}
