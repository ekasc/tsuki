{
  "name": "suki",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "build:cloudflare": "VITE_LOCAL_LIBRARY_ENABLED=0 vite build",
    "verify:release:v1": "node scripts/verify-v1-online-release.mjs",
    "preview": "vite preview",
    "deploy:cloudflare:dry": "VITE_LOCAL_LIBRARY_ENABLED=0 vite build && npx --yes wrangler@4.69.0 deploy --dry-run --config dist/server/wrangler.json --env=\"\"",
    "deploy:cloudflare": "VITE_LOCAL_LIBRARY_ENABLED=0 vite build && npx --yes wrangler@4.69.0 deploy --config dist/server/wrangler.json --env=\"\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:type": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=chromium-desktop",
    "test:e2e:mobile": "playwright test --project=webkit-iphone15pro --project=chromium-galaxys24 --project=webkit-ipadpro11",
    "test:visual": "echo \"Visual regression tests removed\"",
    "test:lighthouse": "pnpm build && LHCI_CHROME_PATH=\"$(node -e 'const { chromium } = require(\"@playwright/test\"); console.log(chromium.executablePath())')\" lhci autorun --config=./lighthouserc.json",
    "test:ci": "pnpm test:type && pnpm test:unit && pnpm build && pnpm test:e2e:desktop && pnpm test:e2e:mobile",
    "lint": "tsc --noEmit",
    "format": "prettier --check .",
    "check": "prettier --write .",
    "playwright": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/react-router-ssr-query": "1.166.11",
    "@tanstack/react-start": "1.167.42",
    "@tanstack/react-virtual": "3.13.24",
    "@tanstack/router-plugin": "1.167.22",
    "better-sqlite3": "12.9.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "file-type": "22.0.1",
    "gsap": "^3.15.0",
    "jszip": "3.10.1",
    "lucide-react": "1.8.0",
    "mime-types": "3.0.2",
    "nanoid": "5.1.9",
    "next-themes": "^0.4.6",
    "p-limit": "7.3.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "0.34.5",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.59.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/mime-types": "3.0.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "0.31.10",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "wrangler": "^4.83.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ]
  }
}